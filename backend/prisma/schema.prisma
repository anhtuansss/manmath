generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExamDifficulty {
  easy
  medium
  hard
}

enum AuthProvider {
  google
  password
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  fullName     String?
  avatarUrl    String?
  googleId     String?      @unique
  passwordHash String?
  authProvider AuthProvider @default(google)
  attempts     Attempt[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Topic {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  order       Int        @default(0)
  questions   Question[]
  subtopics   Subtopic[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Subtopic {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([topicId])
  @@unique([topicId, name])
}

model Exam {
  id               String            @id
  title            String
  description      String
  durationMinutes  Int
  subject          String
  difficulty       ExamDifficulty
  source           String?
  year             Int?
  statusLabel      String
  questions        Question[]
  attempts         Attempt[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt 
}

model Question {
  id            Int      @id 
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  order         Int
  topicId       String?
  topic         Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  subtopicId    String?
  subtopic      Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  question      String
  imageUrl      String?
  options       String[]
  optionImageUrls String[] @default([])
  correctAnswer String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([examId, order])
  @@index([examId])
  @@index([topicId])
  @@index([subtopicId])
}

model Attempt {
  id              String          @id @default(cuid())
  examId          String
  exam            Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  score           Float
  correctCount    Int
  totalQuestions  Int
  unansweredCount Int
  startedAt       DateTime?
  submittedAt     DateTime        @default(now())
  durationSeconds Int?
  answers         AttemptAnswer[]

  @@index([examId])
  @@index([userId])
  @@index([submittedAt])
}

model AttemptAnswer {
  id                  String   @id @default(cuid())
  attemptId           String
  attempt             Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId          Int
  selectedOptionIndex Int?
  correctOptionIndex  Int
  isCorrect           Boolean

  @@index([attemptId])
  @@index([questionId])
  @@unique([attemptId, questionId])
}
