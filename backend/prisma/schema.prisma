generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Đã xóa dòng url theo đúng yêu cầu của Prisma 7
}

model Exam {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}